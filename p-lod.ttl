<http://p-lod.umasscreate.net/vocabulary#1501> a p-lod:wall-painting ;
    p-lod:depicts-visual-motif p-lod:seven-days-of-the-week-motif ;
    p-lod:found-within p-lod:r6-i17 ;
    p-lod:image-url <https://www.pompeiiinpictures.com/pompeiiinpictures/R6/6%2017%2000_files/image005.jpg> ;
    p-lod:pbmp-zotero-entry <https://www.zotero.org/groups/249911/pompeii_bibliography_and_mapping_project/items/itemKey/WDJFGHIQ> ;
    dcterms:description "From left to right the images represent: Chronos/Saturn for Saturday, Sol for Sunday, Luna for Monday, Mars for Tuesday, Mercury for Wednesday, Jupiter for Thursday, Venus for Friday. This is the usual order of the Roman seven-day cycle that became more popular in the 1st century CE." ;
    dcterms:identifier "1501" ;
    dcterms:title "Sequence of Celestial Personifications  Representing Seven-Day Cycle" .

